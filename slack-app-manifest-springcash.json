{
  "display_information": {
    "name": "GTMBot",
    "description": "AI-powered reply drafting and lead qualification with Slack approval workflows",
    "background_color": "#1a1a2e"
  },
  "features": {
    "bot_user": {
      "display_name": "GTMBot",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "chat:write.public",
        "reactions:read",
        "channels:history",
        "groups:history",
        "im:history",
        "mpim:history"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://gtm-signals-scoring-springcash-aero-team-0f650658.vercel.app/slack/interactions"
    },
    "event_subscriptions": {
      "request_url": "https://gtm-signals-scoring-springcash-aero-team-0f650658.vercel.app/slack/events",
      "bot_events": [
        "reaction_added",
        "reaction_removed"
      ]
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false
  }
}
