# GTM Signal Routing Platform — Environment Variables

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Slack ─────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_CHANNEL_OUTBOUND=#outbound-replies
SLACK_CHANNEL_INBOUND=#qualified-leads

# ── LLM ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Deepline (unified API gateway for Attio, Lemlist, Apify) ─
DEEPLINE_API_KEY=...

# ── Lemlist (fallback for operations not yet in Deepline) ────
LEMLIST_API_KEY=...
LEMLIST_CAMPAIGN_IDS=cam_xxx,cam_yyy

# ── Trigger.dev (existing) ────────────────────────────────────
TRIGGER_ACCESS_TOKEN=...

# ── Webhook Relay (set on PRIMARY instance only) ─────────────
# Comma-separated URLs to fan-out webhook events to secondary instances
# Example: https://spring-cash-gtm.vercel.app/api/webhooks/ingest
WEBHOOK_RELAY_TARGETS=

# ── Security ────────────────────────────────────────────────
CRON_SECRET=
ADMIN_API_KEY=
