# GTM Signal Routing Platform — Environment Variables

# === Tenant ===
TENANT_ID=                   # Which tenant config to load: 'deepline' or 'spring-cash' (default: 'deepline')

# === Authentication ===
SESSION_SECRET=              # Random 64-char hex (for signing session cookies)
LOGIN_PASSWORD_HASH=         # scrypt hash of login password

# === Database ===
DATABASE_URL=                # PostgreSQL connection string (auto-provisioned by Neon)

# === Slack ===
SLACK_BOT_TOKEN=             # Bot User OAuth Token (xoxb-...)
SLACK_SIGNING_SECRET=        # Slack app signing secret
SLACK_CHANNEL_OUTBOUND=      # Channel for reply approvals (e.g., #outbound-replies)
SLACK_CHANNEL_INBOUND=       # Channel for qualified leads (e.g., #qualified-leads)

# === LLM ===
OPENAI_API_KEY=              # OpenAI API key (GPT-5-mini for reply drafting)

# === Integrations ===
DEEPLINE_API_KEY=            # Deepline gateway (Attio, Lemlist, Apify)
LEMLIST_API_KEY=             # Lemlist API key
LEMLIST_CAMPAIGN_IDS=        # Comma-separated campaign IDs

# === Security ===
CRON_SECRET=                 # Bearer token for /api/cron/* endpoints
ADMIN_API_KEY=               # Alternative to CRON_SECRET for admin endpoints

# === Config Editor ===
GITHUB_TOKEN=                # GitHub fine-grained PAT (repo contents read/write)
GITHUB_REPO=                 # owner/repo-name

# === Webhook Relay (PRIMARY instance only) ===
WEBHOOK_RELAY_TARGETS=       # Comma-separated URLs for fan-out

# === Background Jobs ===
TRIGGER_ACCESS_TOKEN=        # Trigger.dev project token
